---
interface Props {
  id: string;
  title: string;
  category: string;
  complexity: string;
  status?: string;
  philosophy?: string[];
  technologies?: string[];
  description: string;
  href: string;
}

const props = Astro.props as Props;

const id = props.id;
const title = props.title;
const category = props.category;
const complexity = props.complexity;
const technologies = props.technologies ?? [];
const description = props.description;
const href = props.href;

const philosophy = props.philosophy ?? [
  "Infrastructure as Code.",
  "Architecture as Code."
];

const status = props.status ?? "Completed";
---

<div class="case-card">
  <p class="case-id">{id}</p>

  <h3>{title}</h3>

  <p class="card-philosophy">
    {philosophy[0]}<br />
    {philosophy[1]}
  </p>

  <hr />

  <div class="card-meta">
    <div>
      <span>Domain</span>
      <strong>{category}</strong>
    </div>

    <div>
      <span>Complexity</span>
      <strong>{complexity}</strong>
    </div>

    <div>
      <span>Status</span>
      <strong>{status}</strong>
    </div>
  </div>

  <div class="card-tech">
    <span>Technology</span>
    <p>{technologies.join(" • ")}</p>
  </div>

  <p class="card-description">{description}</p>

  <a href={href} class="button">View Case Study →</a>
</div>